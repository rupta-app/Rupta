# Copy to .env and fill with your Supabase project (Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Cloudflare media delivery (Dashboard → Images / Stream)
EXPO_PUBLIC_CF_ACCOUNT_HASH=your_images_account_hash
EXPO_PUBLIC_CF_STREAM_SUBDOMAIN=customer-yourstreamsubdomain
