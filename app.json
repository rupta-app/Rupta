{
  "expo": {
    "name": "rupta",
    "slug": "rupta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ruptav1.png",
    "scheme": "rupta",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0C0C10"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "backgroundColor": "#0C0C10"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ruptav1.png",
        "backgroundColor": "#0C0C10"
      },
      "predictiveBackGestureEnabled": false,
      "backgroundColor": "#0C0C10",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "Rupta needs photo access to attach SideQuest proof.",
          "cameraPermission": "Rupta uses the camera to record SideQuest proof.",
          "microphonePermission": "Rupta uses the microphone to record videos of your SideQuest proof."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Rupta saves your story card when you choose Save.",
          "savePhotosPermission": "Rupta saves your story card when you choose Save."
        }
      ],
      "expo-video",
      "react-native-compressor"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
