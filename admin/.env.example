# Never commit the service role key. Use only on a trusted machine.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Cloudflare media delivery (same values as the mobile .env)
VITE_CF_ACCOUNT_HASH=your_images_account_hash
VITE_CF_STREAM_SUBDOMAIN=customer-yourstreamsubdomain
